38459>>>                // If from main, this is a propbably a main file Select to Zoom.
38459>>>                Case Break
38460>>>
38460>>>            Case (NavigateData.eNavigateType = nfFromParent)
38463>>>                // If from parent, this is a constrained drill down.
38463>>>                Case Break
38464>>>
38464>>>            Case (NavigateData.eNavigateType = nfFromChild)
38467>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38467>>>                Case Break
38468>>>
38468>>>            Case Else // must be nfUndefined
38468>>>
38468>>>        Case End
38468>>>
38468>>>        Send SetActionButtons
38469>>>
38469>>>    End_Procedure
38470>>>
38470>>>End_Object 
