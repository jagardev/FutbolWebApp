38998>>>>>        tWebNavigateData NavigateData
38998>>>>>        tWebNavigateData NavigateData
38998>>>>>        Boolean bHasRecord
38998>>>>>        Handle hoDD
38998>>>>>
38998>>>>>        Get Server to hoDD
38999>>>>>        Get GetNavigateData to NavigateData
39000>>>>>        Get HasRecord of hoDD to bHasRecord
39001>>>>>
39001>>>>>        // let's hide all buttons and then Show the ones we want
39001>>>>>        WebSet pbRender of oEditBtn to False
39002>>>>>        WebSet pbRender of oSaveBtn to False
39003>>>>>        WebSet pbRender of oCancelChangesBtn to False
39004>>>>>        WebSet pbRender of oDeleteBtn to False
39005>>>>>
39005>>>>>        If (NavigateData.bReadOnly) Begin
39007>>>>>            WebSet pbRender of oEditBtn to True
39008>>>>>        End
39008>>>>>>
39008>>>>>        Else Begin
39009>>>>>            WebSet pbRender of oSaveBtn to True
39010>>>>>            WebSet pbRender of oCancelChangesBtn to True
39011>>>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39012>>>>>        End
39012>>>>>>
39012>>>>>    End_Procedure
