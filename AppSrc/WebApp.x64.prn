38426>>>    Procedure SetActionButtons
38429>>>        tWebNavigateData NavigateData
38429>>>        tWebNavigateData NavigateData
38429>>>        Boolean bHasRecord
38429>>>        Handle hoDD
38429>>>
38429>>>        Get Server to hoDD
38430>>>        Get GetNavigateData to NavigateData
38431>>>        Get HasRecord of hoDD to bHasRecord
38432>>>
38432>>>        // let's hide all buttons and then Show the ones we want
38432>>>        WebSet pbRender of oEditBtn to False
38433>>>        WebSet pbRender of oSaveBtn to False
38434>>>        WebSet pbRender of oCancelChangesBtn to False
38435>>>        WebSet pbRender of oDeleteBtn to False
38436>>>
38436>>>        If (NavigateData.bReadOnly) Begin
38438>>>            WebSet pbRender of oEditBtn to True
38439>>>        End
38439>>>>
38439>>>        Else Begin
38440>>>            WebSet pbRender of oSaveBtn to True
38441>>>            WebSet pbRender of oCancelChangesBtn to True
38442>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38443>>>        End
38443>>>>
38443>>>    End_Procedure
38444>>>
38444>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38447>>>        // Close after save
38447>>>        Send NavigateClose Self
38448>>>    End_Procedure
38449>>>
38449>>>    // this will close the view after a delete
38449>>>    Procedure OnViewDeleted Handle hoDDO
38452>>>        Send NavigateClose Self
38453>>>    End_Procedure
